<Window x:Class="RevitTrackingComparison.UI.Views.ComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:RevitTrackingComparison.UI.Converters"
        Title="{Binding Title}"
        Width="960" Height="640"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Editable value cell: shows the value + pencil; toggles to a textbox + save/cancel + status. -->
        <DataTemplate x:Key="EditableValueCell">
            <Grid VerticalAlignment="Center">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding NewValue}"
                               VerticalAlignment="Center" TextWrapping="Wrap" />
                    <Button Grid.Column="1" Command="{Binding BeginEditCommand}"
                            Style="{StaticResource MaterialDesignToolButton}"
                            ToolTip="Edit value" Padding="4" Margin="4,0,0,0"
                            Visibility="{Binding CanEdit, Converter={StaticResource BoolToVisibility}}">
                        <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" />
                    </Button>
                </Grid>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" VerticalAlignment="Center"
                                 Text="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Command="{Binding SaveCommand}"
                                Style="{StaticResource MaterialDesignToolButton}"
                                ToolTip="Save to Revit" Padding="4" Margin="4,0,0,0">
                            <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" />
                        </Button>
                        <Button Grid.Column="2" Command="{Binding CancelEditCommand}"
                                Style="{StaticResource MaterialDesignToolButton}"
                                ToolTip="Cancel" Padding="4" Margin="2,0,0,0">
                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16" />
                        </Button>
                    </Grid>
                    <TextBlock Text="{Binding Status}" FontSize="11" Opacity="0.7" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}" Text="{Binding Title}" />
            <TextBlock Margin="24,0,0,0" VerticalAlignment="Center"
                       Text="{Binding AddedCount, StringFormat='Added: {0}'}"
                       Foreground="{StaticResource AddedAccentBrush}" />
            <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                       Text="{Binding RemovedCount, StringFormat='Removed: {0}'}"
                       Foreground="{StaticResource RemovedAccentBrush}" />
            <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                       Text="{Binding ModifiedCount, StringFormat='Modified: {0}'}"
                       Foreground="{StaticResource ModifiedAccentBrush}" />
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Added" Style="{StaticResource ComparisonTabAdded}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="120" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3*" MinHeight="160" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" Style="{StaticResource FlatDataGrid}"
                              ItemsSource="{Binding Added}" SelectedItem="{Binding SelectedAdded}"
                              materialDesign:DataGridAssist.CellPadding="12 8 8 8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category" Binding="{Binding After.Category}" Width="Auto" MinWidth="100" />
                            <DataGridTextColumn Header="ID" Binding="{Binding After.ElementId}" Width="Auto" />
                            <DataGridTextColumn Header="UniqueId" Binding="{Binding UniqueId}" Width="Auto" />
                            <DataGridTextColumn Header="Name" Binding="{Binding After.Name}" Width="*" MinWidth="160" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="1" Margin="0,8" Opacity="0.72"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Text="Select an element above to view its parameters."
                               Visibility="{Binding SelectedAdded, Converter={StaticResource NullToVisibility}, ConverterParameter=invert}" />

                    <DataGrid Grid.Row="2" Style="{StaticResource FlatDataGrid}"
                              ItemsSource="{Binding SelectedAddedParameters}"
                              Visibility="{Binding SelectedAdded, Converter={StaticResource NullToVisibility}}"
                              materialDesign:DataGridAssist.CellPadding="12 8 8 8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Parameter" Binding="{Binding Name}" Width="Auto" MinWidth="160" />
                            <DataGridTemplateColumn Header="Value" Width="*" MinWidth="200"
                                                    CellTemplate="{StaticResource EditableValueCell}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Removed" Style="{StaticResource ComparisonTabRemoved}">
                <DataGrid Style="{StaticResource FlatDataGrid}" ItemsSource="{Binding Removed}"
                          materialDesign:DataGridAssist.CellPadding="12 8 8 8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category" Binding="{Binding Before.Category}" Width="Auto" MinWidth="100" />
                        <DataGridTextColumn Header="ID" Binding="{Binding Before.ElementId}" Width="Auto" />
                        <DataGridTextColumn Header="UniqueId" Binding="{Binding UniqueId}" Width="Auto" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Before.Name}" Width="*" MinWidth="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Modified" Style="{StaticResource ComparisonTabModified}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="120" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3*" MinHeight="160" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" Style="{StaticResource FlatDataGrid}"
                              ItemsSource="{Binding Modified}" SelectedItem="{Binding SelectedModified}"
                              materialDesign:DataGridAssist.CellPadding="12 8 8 8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category" Binding="{Binding After.Category}" Width="Auto" MinWidth="100" />
                            <DataGridTextColumn Header="ID" Binding="{Binding After.ElementId}" Width="Auto" />
                            <DataGridTextColumn Header="UniqueId" Binding="{Binding UniqueId}" Width="Auto" />
                            <DataGridTextColumn Header="Name" Binding="{Binding After.Name}" Width="*" MinWidth="160" />
                            <DataGridTextColumn Header="Changes" Binding="{Binding ChangedParameters.Count}" Width="Auto" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="1" Margin="0,8" Opacity="0.72"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Text="Select an element above to view parameter changes."
                               Visibility="{Binding SelectedModified, Converter={StaticResource NullToVisibility}, ConverterParameter=invert}" />

                    <DataGrid Grid.Row="2" Style="{StaticResource FlatDataGrid}"
                              ItemsSource="{Binding SelectedParameters}"
                              Visibility="{Binding SelectedModified, Converter={StaticResource NullToVisibility}}"
                              materialDesign:DataGridAssist.CellPadding="12 8 8 8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Parameter" Binding="{Binding Name}" Width="Auto" MinWidth="160" />
                            <DataGridTextColumn Header="Old value" Binding="{Binding OldValue}" Width="*" MinWidth="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="New value" Width="*" MinWidth="200"
                                                    CellTemplate="{StaticResource EditableValueCell}" />
                        </DataGrid.Columns>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ValuesDiffer}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource ChangedParameterBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
