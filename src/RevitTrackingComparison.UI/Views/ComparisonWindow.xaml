<Window x:Class="RevitTrackingComparison.UI.Views.ComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="900" Height="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
            <TextBlock Margin="20,0,0,0" VerticalAlignment="Center"
                       Text="{Binding AddedCount, StringFormat='Added: {0}'}" Foreground="Green" />
            <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                       Text="{Binding RemovedCount, StringFormat='Removed: {0}'}" Foreground="Red" />
            <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                       Text="{Binding ModifiedCount, StringFormat='Modified: {0}'}" Foreground="DarkOrange" />
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Added">
                <DataGrid ItemsSource="{Binding Added}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category" Binding="{Binding After.Category}" Width="200" />
                        <DataGridTextColumn Header="Name" Binding="{Binding After.Name}" Width="*" />
                        <DataGridTextColumn Header="UniqueId" Binding="{Binding UniqueId}" Width="260" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Removed">
                <DataGrid ItemsSource="{Binding Removed}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category" Binding="{Binding Before.Category}" Width="200" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Before.Name}" Width="*" />
                        <DataGridTextColumn Header="UniqueId" Binding="{Binding UniqueId}" Width="260" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Modified">
                <DataGrid ItemsSource="{Binding Modified}" AutoGenerateColumns="False" IsReadOnly="True"
                          RowDetailsVisibilityMode="VisibleWhenSelected">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category" Binding="{Binding After.Category}" Width="200" />
                        <DataGridTextColumn Header="Name" Binding="{Binding After.Name}" Width="*" />
                        <DataGridTextColumn Header="Changed parameters"
                                            Binding="{Binding ChangedParameters.Count}" Width="180" />
                    </DataGrid.Columns>
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <DataGrid ItemsSource="{Binding ChangedParameters}" AutoGenerateColumns="False"
                                      IsReadOnly="True" HeadersVisibility="Column" Margin="20,4,4,4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Parameter" Binding="{Binding Name}" Width="220" />
                                    <DataGridTextColumn Header="Old value" Binding="{Binding OldValue}" Width="*" />
                                    <DataGridTextColumn Header="New value" Binding="{Binding NewValue}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>