<Window x:Class="RevitTrackingComparison.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Snapshots"
        Width="400" MinWidth="360" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,20"
                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                   Text="{Binding Project, StringFormat='Project: {0}'}"
                   TextTrimming="CharacterEllipsis" />

        <Button Grid.Row="1" Style="{StaticResource PrimaryButton}" Content="Take snapshot"
                Command="{Binding TakeSnapshotCommand}" />
        <Button Grid.Row="2" Style="{StaticResource PrimaryButton}" Content="Capture settings"
                Command="{Binding OpenSettingsCommand}" />
        <Button Grid.Row="3" Style="{StaticResource PrimaryButton}" Content="Compare snapshots"
                Command="{Binding OpenCompareCommand}" />
        <Button Grid.Row="4" Style="{StaticResource PrimaryButton}" Content="Export snapshot to CSV"
                Command="{Binding OpenExportCommand}" />

        <TextBlock Grid.Row="5" Margin="0,12,0,0" TextWrapping="Wrap"
                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                   Opacity="0.72" Text="{Binding Status}" />
    </Grid>
</Window>
